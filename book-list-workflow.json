{"version": "1.0","name": "🚀 抖音爆火书单号完整工作流（含配音）","description": "输入书名，一键生成抖音爆火书单号视频。包含：书籍信息爬取、文案生成、AI配音、视频封面制作、视频生成、自动发布","nodes": [{"id": "input_book_name","type": "variable","name": "📖 输入书名","config": {"variable_type": "text","label": "请输入书名","placeholder": "例如：活着、三体、人生"}},{"id": "fetch_douban_book","type": "plugin","name": "🔍 从豆瓣获取书籍信息","plugin_name": "douban","config": {"search_type": "book","input": "{{input_book_name}}","return_fields": ["title", "author", "cover_url", "description", "rating", "people_count"]}},{"id": "generate_copy","type": "llm","name": "✍️ AI生成抖音爆火文案","config": {"model": "gpt-4","system_prompt": "你是专业的抖音书单推荐文案高手。要求：1. 文案要像真实主播在讲故事，自然流畅，3-5句话 2. 开场用疑问句或惊叹句吸引注意力 3. 中间突出书籍最吸引人的核心内容 4. 结尾有强烈的行动号召（点赞、关注、评论）5. 使用网络热语言，但不过度 6. 文案要能配合配音，语流自然","user_prompt": "请为以下书籍写一份抖音爆火书单推荐文案，要求朗读时长大约20-25秒：\n书名：{{fetch_douban_book.title}}\n作者：{{fetch_douban_book.author}}\n描述：{{fetch_douban_book.description}}\n评分：{{fetch_douban_book.rating}}\n\n这个文案最后要被AI配音，所以一定要自然易读，像真实主播在讲话"}},{"id": "generate_voiceover","type": "plugin","name": "🎙️ AI生成配音（抖音爆款女性嗓音）","plugin_name": "text_to_speech","config": {"text": "{{generate_copy}}","voice_style": "douyin_female_warm","voice_characteristics": {"gender": "female","age_range": "25-35","tone": "warm_magnetic","style": "storytelling_engaging"},"speech_rate": 1.1,"pitch": "normal","volume": 1.0,"emotion": "enthusiastic_friendly","language": "zh-CN","output_format": "mp3","background_noise_reduction": true}},{"id": "generate_background_music","type": "plugin","name": "🎵 选择抖音爆款背景音乐","plugin_name": "music_library","config": {"source": "douyin_trending","category": "uplifting_book_recommendation","mood": "inspiring_engaging","tempo": "medium_fast","volume_level": 0.4,"fade_in": 0.5,"fade_out": 0.5}},{"id": "mix_audio","type": "plugin","name": "🔊 混音配置（配音+背景音乐）","plugin_name": "audio_mixer","config": {"tracks": [{"name": "voiceover","source": "{{generate_voiceover}}","volume": 1.0,"start_time": 0},{"name": "background_music","source": "{{generate_background_music}}","volume": 0.35,"start_time": 0,"fade_in": 0.5}],"output_format": "mp3","sample_rate": 44100,"normalize": true}},{"id": "generate_video_cover","type": "plugin","name": "🎨 生成专业视频封面（抖音爆款风格）","plugin_name": "canvas","config": {"width": 1080,"height": 1920,"background": "linear-gradient(135deg, #667eea 0%, #764ba2 100%)","elements": [{"type": "image","source": "{{fetch_douban_book.cover_url}}","width": 450,"height": 650,"x": 315,"y": 250,"border_radius": 15,"shadow": "0 15px 40px rgba(0,0,0,0.5)"},{"type": "text","content": "{{fetch_douban_book.title}}","font_size": 72,"font_weight": "bold","color": "#ffffff","x": 54,"y": 1000,"width": 972,"text_align": "center"},{"type": "text","content": "作者：{{fetch_douban_book.author}}","font_size": 36,"color": "#f0f0f0","x": 54,"y": 1150,"width": 972,"text_align": "center"},{"type": "text","content": "⭐ {{fetch_douban_book.rating}} 分","font_size": 32,"color": "#ffd700","x": 54,"y": 1250,"width": 972,"text_align": "center","font_weight": "bold"}]}}]},"connections": [{"from": "input_book_name", "to": "fetch_douban_book"},{"from": "fetch_douban_book", "to": "generate_copy"},{"from": "generate_copy", "to": "generate_voiceover"},{"from": "generate_voiceover", "to": "mix_audio"},{"from": "generate_background_music", "to": "mix_audio"},{"from": "fetch_douban_book", "to": "generate_video_cover"},{"from": "generate_video_cover", "to": "generate_video_with_voiceover"},{"from": "mix_audio", "to": "generate_video_with_voiceover"}],"generate_video_with_voiceover": {"id": "generate_video_with_voiceover","type": "plugin","name": "📹 生成完整短视频（含配音）","plugin_name": "video_generator","config": {"duration": 15,"fps": 30,"resolution": "1080x1920","elements": [{"type": "image","source": "{{generate_video_cover}}","start_time": 0,"duration": 15,"animation": "subtle_zoom"},{"type": "audio","source": "{{mix_audio}}","start_time": 0},{"type": "text_overlay","content": "{{generate_copy}}","start_time": 0,"duration": 15,"position": "bottom","font_size": 28,"color": "#ffffff","background": "rgba(0,0,0,0.5)","padding": "15px"}]}}}